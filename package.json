{
    "name": "pb-streamdeck-plugin",
    "version": "1.0.0",
    "description": "Stream Deck plugin (PhantomBot Control): drive PhantomBot from keys via its authenticated HTTP API.",
    "repository": {
        "type": "git",
        "url": "https://github.com/mcawful/pb-streamdeck-plugin.git"
    },
    "bugs": {
        "url": "https://github.com/mcawful/pb-streamdeck-plugin/issues"
    },
    "keywords": [
        "stream-deck",
        "elgato",
        "phantombot",
        "plugin"
    ],
    "scripts": {
        "build": "rollup -c",
        "validate": "streamdeck validate com.mcawful.pbstreamdeck.sdPlugin",
        "pack": "npm run build && streamdeck pack com.mcawful.pbstreamdeck.sdPlugin",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.mcawful.pbstreamdeck\""
    },
    "type": "module",
    "prettier": "@elgato/prettier-config",
    "devDependencies": {
        "@elgato/cli": "^1.7.0",
        "@elgato/prettier-config": "^0.2.5",
        "@rollup/plugin-commonjs": "^28.0.2",
        "@rollup/plugin-node-resolve": "^16.0.0",
        "@rollup/plugin-typescript": "^12.1.2",
        "@tsconfig/node20": "^20.1.4",
        "@types/node": "22.13.0",
        "rollup": "^4.32.1",
        "tslib": "^2.8.1",
        "typescript": "^5.7.3",
        "vitest": "^3.1.1"
    },
    "dependencies": {
        "@elgato/streamdeck": "^2.0.1",
        "undici": "^7.5.0"
    }
}
