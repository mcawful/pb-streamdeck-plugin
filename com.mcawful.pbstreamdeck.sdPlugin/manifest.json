{
    "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
    "Name": "PhantomBot Control",
    "Version": "1.0.0.0",
    "Author": "McAwful",
    "Actions": [
        {
            "Name": "Run Command",
            "UUID": "com.mcawful.pbstreamdeck.command",
            "Icon": "imgs/actions/command/icon",
            "Tooltip": "Run a PhantomBot chat command.",
            "PropertyInspectorPath": "ui/phantomControl.html",
            "Controllers": [
                "Keypad"
            ],
            "States": [
                {
                    "Image": "imgs/actions/command/key",
                    "TitleAlignment": "middle"
                }
            ]
        }
    ],
    "Category": "PhantomBot",
    "CategoryIcon": "imgs/plugin/category-icon",
    "CodePath": "bin/plugin.js",
    "Description": "Third-party plugin to control PhantomBot from your Stream Deck.",
    "URL": "https://github.com/mcawful/pb-streamdeck-plugin",
    "SupportURL": "https://github.com/mcawful/pb-streamdeck-plugin/issues",
    "Icon": "imgs/plugin/marketplace",
    "SDKVersion": 3,
    "Software": {
        "MinimumVersion": "6.9"
    },
    "OS": [
        {
            "Platform": "mac",
            "MinimumVersion": "10.15"
        },
        {
            "Platform": "windows",
            "MinimumVersion": "10"
        }
    ],
    "Nodejs": {
        "Version": "20",
        "Debug": "disabled"
    },
    "UUID": "com.mcawful.pbstreamdeck"
}
